{
    "name": "comment-released-prs-action",
    "version": "3.0.0",
    "description": "A GitHub action that adds release comments and labels to PRs",
    "author": "Radoslav Stoyanov <r.stoyanov@outlook.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rdlf0/comment-released-prs-action"
    },
    "scripts": {
        "compile": "tsc && ncc build src/index.js -m --license licenses.txt",
        "test": "node --import tsx --test \"src/**/*.test.ts\""
    },
    "keywords": [
        "actions",
        "release",
        "comment",
        "label",
        "node",
        "typescript"
    ],
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "dependencies": {
        "@actions/core": "^3.0.1",
        "@actions/github": "^9.1.1",
        "@octokit/webhooks": "^14.2.0"
    },
    "devDependencies": {
        "@types/node": "^24.13.2",
        "@vercel/ncc": "^0.44.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    },
    "allowScripts": {
        "esbuild@0.28.0": true
    }
}
